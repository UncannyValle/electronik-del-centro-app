# Copy this file to .env.local and replace values.
# Do NOT commit .env.local with real credentials.

# Your Shopify store domain (no protocol)
# Example: your-store.myshopify.com
SHOPIFY_STORE_DOMAIN=https://electronik-dev.myshopify.com

# Storefront API version
# Example: 2025-10
SHOPIFY_STOREFRONT_API_VERSION=2025-10

# Headless channel Storefront PUBLIC access token
# Safe for client-side Storefront API calls (still treat carefully)
SHOPIFY_STOREFRONT_PUBLIC_ACCESS_TOKEN=replace-with-public-token

# Headless channel Storefront PRIVATE access token
# Server-side only. Never expose this in browser/client bundles.
SHOPIFY_STOREFRONT_PRIVATE_ACCESS_TOKEN=replace-with-private-token

# Optional: use dummy data only when this is explicitly true.
# true | false
NEXT_PUBLIC_USE_DUMMY_DATA=false
