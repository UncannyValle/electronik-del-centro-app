# Copy this file to .env.local and replace values.
# Do NOT commit .env.local with real credentials.

# Full Storefront GraphQL endpoint (authoritative if set)
# Format: https://{store}.myshopify.com/api/{version}/graphql.json
SHOPIFY_STOREFRONT_GRAPHQL_ENDPOINT=https://electronik-dev.myshopify.com/api/2025-10/graphql.json

# Your Shopify store domain (fallback when endpoint is not provided)
# Example: your-store.myshopify.com
SHOPIFY_STORE_DOMAIN=electronik-dev.myshopify.com

# Storefront API version (fallback when endpoint is not provided)
# Example: 2025-10
SHOPIFY_STOREFRONT_API_VERSION=2025-10

# Headless channel Storefront PUBLIC access token
# Safe for client-side Storefront API calls (still treat carefully)
SHOPIFY_STOREFRONT_PUBLIC_ACCESS_TOKEN=replace-with-public-token

# Headless channel Storefront PRIVATE access token
# Server-side only. Never expose this in browser/client bundles.
SHOPIFY_STOREFRONT_PRIVATE_ACCESS_TOKEN=replace-with-private-token

# Optional contact fallbacks when shop metafields are missing
STORE_CONTACT_PHONE=
STORE_CONTACT_EMAIL=
STORE_CONTACT_ADDRESS_LINE_1=
STORE_CONTACT_CITY_STATE_ZIP=
STORE_CONTACT_FACEBOOK_URL=
STORE_CONTACT_INSTAGRAM_URL=
